#!/bin/bash

# agent-talk - Send messages to running agents on remote machines
# Usage: agent-talk <agent-id> <message>
#   or:  agent-talk --list
#   or:  agent-talk --status <agent-id>

set -e

STATE_FILE="$HOME/.claude-agent-tracker/state.json"
SESSIONS_FILE="$HOME/.claude/morpheus/sessions.json"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

function error() {
  echo -e "${RED}Error: $1${NC}" >&2
  exit 1
}

function success() {
  echo -e "${GREEN}✓ $1${NC}"
}

function info() {
  echo -e "${BLUE}ℹ $1${NC}"
}

function warn() {
  echo -e "${YELLOW}⚠ $1${NC}"
}

# Check prerequisites
[[ ! -f "$STATE_FILE" ]] && error "Agent tracker not found at $STATE_FILE"
[[ ! -f "$SESSIONS_FILE" ]] && error "Morpheus sessions not found at $SESSIONS_FILE"

# List all tracked agents
function list_agents() {
  echo -e "${BLUE}Tracked Agents${NC}"
  echo "=============="
  
  jq -r '.agents | to_entries[] | "\(.key)\n  Task: \(.value.task_description)\n  Status: \(.value.last_status)\n  DevPod: \(.value.hostname)\n"' "$STATE_FILE"
}

# Get agent status
function get_status() {
  local agent_id="$1"
  
  # Get agent info from tracker
  local agent_data=$(jq -r ".agents[\"$agent_id\"]" "$STATE_FILE")
  [[ "$agent_data" == "null" ]] && error "Agent '$agent_id' not found in tracker"
  
  local session_id=$(echo "$agent_data" | jq -r '.morpheus_session_id')
  local hostname=$(echo "$agent_data" | jq -r '.hostname')
  
  # Get session info from Morpheus
  local session_data=$(jq -r ".[] | select(.id==\"$session_id\")" "$SESSIONS_FILE")
  [[ "$session_data" == "" ]] && error "Session not found in Morpheus"
  
  local tmux_session=$(echo "$session_data" | jq -r '.tmuxSessionName')
  local status=$(echo "$session_data" | jq -r '.status')
  
  echo -e "${BLUE}Agent: $agent_id${NC}"
  echo "Status: $status"
  echo "DevPod: $hostname"
  echo "Session: $session_id"
  echo "Tmux: $tmux_session"
  
  # Get recent output
  info "Recent output (last 10 lines):"
  ssh -o ControlPath=/tmp/morpheus-ssh-sth@${hostname}:22 ${hostname} \
    "tmux capture-pane -t $tmux_session -p -S -10" 2>/dev/null || warn "Could not fetch output"
}

# Watch agent output in real-time
function watch_agent() {
  local agent_id="$1"
  local lines="${2:-30}"
  
  # Get agent info
  local agent_data=$(jq -r ".agents[\"$agent_id\"]" "$STATE_FILE")
  [[ "$agent_data" == "null" ]] && error "Agent '$agent_id' not found"
  
  local session_id=$(echo "$agent_data" | jq -r '.morpheus_session_id')
  local hostname=$(echo "$agent_data" | jq -r '.hostname')
  local task=$(echo "$agent_data" | jq -r '.task_description')
  
  # Get tmux session from Morpheus
  local tmux_session=$(jq -r ".[] | select(.id==\"$session_id\") | .tmuxSessionName" "$SESSIONS_FILE")
  [[ "$tmux_session" == "" ]] && error "Session not found in Morpheus"
  
  info "Watching agent '$agent_id' on $hostname"
  info "Task: $task"
  echo -e "${YELLOW}Press Ctrl+C to stop watching${NC}\n"
  
  # Watch tmux pane output
  while true; do
    clear
    echo -e "${BLUE}━━━ Agent: $agent_id ━━━ $(date +%H:%M:%S) ━━━${NC}"
    ssh -o ControlPath=/tmp/morpheus-ssh-sth@${hostname}:22 ${hostname} \
      "tmux capture-pane -t $tmux_session -p -S -${lines}" 2>/dev/null || {
      error "Lost connection to agent"
    }
    sleep 2
  done
}

# Send message to agent
function send_message() {
  local agent_id="$1"
  local message="$2"
  
  # Get agent info
  local agent_data=$(jq -r ".agents[\"$agent_id\"]" "$STATE_FILE")
  [[ "$agent_data" == "null" ]] && error "Agent '$agent_id' not found"
  
  local session_id=$(echo "$agent_data" | jq -r '.morpheus_session_id')
  local hostname=$(echo "$agent_data" | jq -r '.hostname')
  
  # Get tmux session from Morpheus
  local tmux_session=$(jq -r ".[] | select(.id==\"$session_id\") | .tmuxSessionName" "$SESSIONS_FILE")
  [[ "$tmux_session" == "" ]] && error "Session not found in Morpheus"
  
  info "Sending message to agent '$agent_id' on $hostname..."
  
  # Send message via tmux
  ssh -o ControlPath=/tmp/morpheus-ssh-sth@${hostname}:22 ${hostname} \
    "tmux send-keys -t $tmux_session '$message' Enter" || error "Failed to send message"
  
  success "Message sent to $agent_id"
  
  # Wait and show response
  sleep 3
  info "Recent output:"
  ssh -o ControlPath=/tmp/morpheus-ssh-sth@${hostname}:22 ${hostname} \
    "tmux capture-pane -t $tmux_session -p -S -15" 2>/dev/null || warn "Could not fetch output"
}

# Main
case "${1:-}" in
  --list|-l)
    list_agents
    ;;
  --status|-s)
    [[ -z "$2" ]] && error "Usage: agent-talk --status <agent-id>"
    get_status "$2"
    ;;
  --watch|-w)
    [[ -z "$2" ]] && error "Usage: agent-talk --watch <agent-id> [lines]"
    watch_agent "$2" "${3:-30}"
    ;;
  --help|-h)
    cat <<EOF
agent-talk - Communicate with remote Claude agents

Usage:
  agent-talk <agent-id> <message>        Send a message to an agent
  agent-talk --list                      List all tracked agents
  agent-talk --status <agent-id>         Get agent status and recent output
  agent-talk --watch <agent-id> [lines]  Watch agent output in real-time (default: 30 lines)
  agent-talk --help                      Show this help

Examples:
  agent-talk test-readme-edit "Create a PR using arh"
  agent-talk --list
  agent-talk --status test-readme-edit
  agent-talk --watch test-readme-edit 50

EOF
    ;;
  *)
    [[ -z "$1" ]] && error "Usage: agent-talk <agent-id> <message> (or --help for more options)"
    [[ -z "$2" ]] && error "Usage: agent-talk <agent-id> <message>"
    send_message "$1" "$2"
    ;;
esac
